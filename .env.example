# Supabase Configuration
# Get these values from: https://supabase.com/dashboard/project/_/settings/api
# IMPORTANT: Copy this file to .env and replace with your actual values

# Your Supabase project URL (example: https://abcdefghij.supabase.co)
VITE_SUPABASE_URL=""

# Your Supabase anon/public key (starts with "eyJ..." - safe for frontend)
VITE_SUPABASE_ANON_KEY=""

# Authentication & Email Redirects
# Set this to your production domain for email links to work correctly
# Examples:
#   Local development: http://localhost:3000
#   Production: https://finance-tracker.yourdomain.com
# If empty, uses window.location.origin dynamically
VITE_AUTH_REDIRECT_URL=""

# Email Configuration
# Email address to display in sign-up confirmation and password reset emails
# (Optional - Supabase handles default email sending)
VITE_EMAIL_FROM_ADDRESS=""

# Server Port Configuration
PORT=3000

# Environment
NODE_ENV=development

# See DATABASE_README.md for complete setup instructions